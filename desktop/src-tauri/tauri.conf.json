{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Cairn",
  "version": "0.1.0",
  "identifier": "com.shaho.cairn",
  "build": {
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir ../web dev",
    "beforeBuildCommand": "pnpm --dir ../web build && node ../scripts/build-sidecar.mjs",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Cairn",
        "width": 1280,
        "height": 832,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/cairn"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ShahramMebashar/cairn/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFDNjNBMTVFNEY5MDU4NEEKUldSS1dKQlBYcUZqSEFuWGtEdnY5NHQ2UnozTFhrcWdaOVRvNG9GcGw3aVpMb3NudFo2bkVSYmMK"
    }
  }
}
